# 代射引擎设置
EVENT_MAX = 10000 # 这里是整个ains_active_nodes表中event_tuple字段内容之和的上限，如果实际超出，就会触发代射引擎
EVENT_LOSS = 3000 # 距上次访问时间（秒）大于此值，且权重为0，event_tuple为NULL
TICK_INTERVAL = 10 # 权重计算时间间隔

# 事件检索设设置
MAX_CHATS = 2000 # 每检索允许的最大字符数
