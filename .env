# PostgreSQL数据库设置
DB_HOST="192.168.66.39"
DB_DATABASE="causal_ai_db"
DB_USER="postgres"
DB_PASSWORD="Shift962512"
DB_PORT=5432

# 代射引擎设置
EVENT_MAX = 1000000 # 这里是整个ains_active_nodes表中event_tuple字段内容之和的上限，如果实际超出，就会触发代射引擎
EVENT_LOSS = 3000 # 距上次访问时间（秒）大于此值，且权重为0，event_tuple为NULL
TICK_INTERVAL = 60 # 权重计算时间间隔

# 事件检索设设置
MAX_CHATS = 2000 # 每检索允许的最大字符数
MAX_EYES=30 # 事件视界半径（视距），以大股东节点为圆心，到其它事件节点的半径向量距离，它决定了LLM一次性"看到"的视线范围
HORIZON_DETAIL=0 # 视界内非焦点节点是否返回因果链（0=不返回节省Token，1=返回parent_ids+next_ids）

# Ollama 向量化模型设置
OLLAMA_HOST="192.168.68.28"
OLLAMA_PORT=11434
OLLAMA_EMBED_MODEL="nomic-embed-text"

# llm 设置
API_KEY="not-needed"
BASE_URL="http://192.168.66.43:9382/llm/v1"
MODEL="local-llm"

# API 行为设置
RETURN_SERIAL_ID_ON_GENESIS=False # 是否在创建节点时返回serial_id（开启会增加一次查询开销）
